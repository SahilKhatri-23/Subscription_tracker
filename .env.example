# ========================================
# Subscription Tracker API - Environment Variables
# ========================================
# 
# IMPORTANT: This is an EXAMPLE file. 
# Copy this file to .env.development.local or .env.production.local
# and fill in your actual values. NEVER commit files with real secrets!
#
# Usage:
# 1. Copy: cp .env.example .env.development.local
# 2. Edit: Add your actual values to the new file
# 3. Never commit: Add .env* files to .gitignore
#

# ========================================
# SERVER CONFIGURATION
# ========================================
PORT=5000
NODE_ENV=development

# ========================================
# DATABASE CONFIGURATION
# ========================================
# Local MongoDB:
DB_URI=mongodb://localhost:27017/subscription-tracker

# MongoDB Atlas Cloud (recommended for production):
# DB_URI=mongodb+srv://username:password@cluster-name.mongodb.net/subscription-tracker?retryWrites=true&w=majority

# ========================================
# JWT AUTHENTICATION
# ========================================
# Change this to a long, random string (min 32 characters)
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production_min_32_chars
JWT_EXPIRES_IN=7d

# ========================================
# ARCJET SECURITY & RATE LIMITING
# ========================================
ARCJET_KEY=your_arcjet_api_key
ARCJET_ENV=production

# ========================================
# CORS CONFIGURATION
# ========================================
CORS_ORIGIN=http://localhost:3000

# ========================================
# EMAIL CONFIGURATION (Optional - Future Feature)
# ========================================
# Email automation features are planned for future releases
# Uncomment and configure these when email features are implemented
# EMAIL_USER=your-email@gmail.com
# EMAIL_PASSWORD=your-app-password
# EMAIL_FROM=noreply@subscriptiontracker.com

# ========================================
# APPLICATION INFO
# ========================================
APP_NAME=Subscription Tracker API
APP_VERSION=1.0.0

# ========================================
# ADDITIONAL SERVICES (Optional)
# ========================================
# Stripe Integration (for payment processing)
STRIPE_SECRET_KEY=sk_test_your_stripe_key

# SendGrid Integration (for email)
SENDGRID_API_KEY=your_sendgrid_key

# AWS S3 (for file uploads)
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_S3_BUCKET=your_bucket_name
AWS_REGION=us-east-1

# ========================================
# LOGGING & DEBUGGING
# ========================================
LOG_LEVEL=info
DEBUG=false

# ========================================
# NOTES:
# ========================================
# - Never commit files with real secrets to Git
# - Use different secrets for development and production
# - Rotate secrets periodically
# - Store production secrets in secure vaults (AWS Secrets Manager, HashiCorp Vault)
# - For CI/CD pipelines, use environment variables or secret management tools
